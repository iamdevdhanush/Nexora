datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  role      String
  createdAt DateTime @default(now())
}

model Hackathon {
  id        String   @id @default(uuid())
  name      String
  date      DateTime
  createdAt DateTime @default(now())
}

model Team {
  id          String   @id @default(uuid())
  name        String
  hackathonId String
  createdAt   DateTime @default(now())
}

model Participant {
  id     String @id @default(uuid())
  name   String
  email  String
  teamId String
}
